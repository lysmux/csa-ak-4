// Project Euler Problem 4: Largest Palindrome Product
// The largest palindrome made from the product of two 3-digit numbers is
// 906609 = 913 * 993. Brute force search across all pairs (i, j) with
// i <= j, keeping the largest palindromic product.

fun reverse(int n): int {
    var rev: int = 0;
    while (n > 0) {
        rev = rev * 10 + n - n / 10 * 10;
        n = n / 10;
    }
    return rev;
}

fun is_palindrome(int n): bool {
    return reverse(n) == n;
}

fun main(): int {
    var max_pal: int = 0;
    var i: int = 100;
    while (i <= 999) {
        var j: int = i;
        while (j <= 999) {
            var product: int = i * j;
            if (product > max_pal) {
                if (is_palindrome(product)) {
                    max_pal = product;
                }
            }
            j++;
        }
        i++;
    }
    print(max_pal);
    return max_pal;
}
