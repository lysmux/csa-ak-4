{
  "name": "Cube",
  "scopeName": "source.cube",
  "fileTypes": ["cube"],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.cube",
          "match": "//.*$"
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.cube",
          "match": "\\b(const|var|fun|if|else|while|return)\\b"
        }
      ]
    },

    "types": {
      "patterns": [
        {
          "name": "storage.type.cube",
          "match": "\\b(int|long|byte|bool|string|void)\\b"
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.cube",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.cube",
              "match": "\\\\."
            }
          ]
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.cube",
          "match": "\\b\\d+\\b"
        }
      ]
    },

    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.cube",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.cube",
          "match": "(\\+\\+|--|==|!=|>=|<=|&&|\\|\\||[+\\-*/=<>!])"
        }
      ]
    }
  }
}
